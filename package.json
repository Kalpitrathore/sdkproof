{
  "name": "sdkproof",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "prisma generate --schema fixtures/prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "start": "tsx src/cli.ts",
    "score": "tsx src/cli.ts run --lib prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@prisma/client": "^7.8.0",
    "openai": "^6.47.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
