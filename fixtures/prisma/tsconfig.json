{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@prisma/client": ["./generated/client/client.ts"]
    }
  },
  "include": ["candidate.ts"]
}
